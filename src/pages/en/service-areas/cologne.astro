---
import BaseHead from "../../../components/base/BaseHead.astro";
import Footer from "../../../components/base/Footer.astro";
import Navigation from "../../../components/base/Navigation.astro";
import CallToAction from "../../../components/widgets/CallToAction.astro";
import FAQ from "../../../components/widgets/FAQ.astro";
import HeroSubpage from "../../../components/widgets/HeroSubpage.astro";
import ImageText from "../../../components/widgets/ImageText.astro";
import ItemList from "../../../components/widgets/ItemList.astro";
import TextBlock from "../../../components/widgets/TextBlock.astro";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../../i18n/utils";
import { imageProvider } from "../../../provider/imageProvider";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const locationItems = [
  {
    title: t("mobileCocktailbarKoln.locations.item1.title"),
    description: t("mobileCocktailbarKoln.locations.item1.description"),
  },
  {
    title: t("mobileCocktailbarKoln.locations.item2.title"),
    description: t("mobileCocktailbarKoln.locations.item2.description"),
  },
  {
    title: t("mobileCocktailbarKoln.locations.item3.title"),
    description: t("mobileCocktailbarKoln.locations.item3.description"),
  },
  {
    title: t("mobileCocktailbarKoln.locations.item4.title"),
    description: t("mobileCocktailbarKoln.locations.item4.description"),
  },
];

const occasionItems = [
  {
    title: t("mobileCocktailbarKoln.occasions.item1.title"),
    description: t("mobileCocktailbarKoln.occasions.item1.description"),
  },
  {
    title: t("mobileCocktailbarKoln.occasions.item2.title"),
    description: t("mobileCocktailbarKoln.occasions.item2.description"),
  },
  {
    title: t("mobileCocktailbarKoln.occasions.item3.title"),
    description: t("mobileCocktailbarKoln.occasions.item3.description"),
  },
];

const faqItems = [
  {
    question: t("mobileCocktailbarKoln.faq.q1"),
    answer: t("mobileCocktailbarKoln.faq.a1"),
  },
  {
    question: t("mobileCocktailbarKoln.faq.q2"),
    answer: t("mobileCocktailbarKoln.faq.a2"),
  },
  {
    question: t("mobileCocktailbarKoln.faq.q3"),
    answer: t("mobileCocktailbarKoln.faq.a3"),
  },
];

const koelnHeroUrl =
  typeof imageProvider.hero.koelnDomBruecke.src === "object"
    ? imageProvider.hero.koelnDomBruecke.src.src
    : imageProvider.hero.koelnDomBruecke.src;

const galleryImages = [
  { url: "https://picsum.photos/600/400?random=1", alt: "Cocktail event at Rheinauhafen Cologne" },
  { url: "https://picsum.photos/400/600?random=2", alt: "Mobile bar at corporate party in Cologne" },
  { url: "https://picsum.photos/600/600?random=3", alt: "Wedding reception with cocktail bar Cologne" },
  { url: "https://picsum.photos/500/350?random=4", alt: "Bartender service at Cologne venue" },
  { url: "https://picsum.photos/450/600?random=5", alt: "Event catering Cologne" },
  { url: "https://picsum.photos/600/450?random=6", alt: "Mobile cocktail bar Cologne" },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead
      title={t("mobileCocktailbarKoln.meta.title")}
      description={t("mobileCocktailbarKoln.meta.description")}
      lang={lang}
    />
  </head>
  <body>
    <div class="relative">
      <Navigation />
      <main>
        <HeroSubpage
          title={t("mobileCocktailbarKoln.hero.title")}
          imageUrl={koelnHeroUrl}
        />
        <ImageText
          badgeText={t("mobileCocktailbarKoln.intro.badge")}
          buttonText={t("hero.cta")}
          checkItems={[
            t("mobileCocktailbarKoln.intro.bullet1"),
            t("mobileCocktailbarKoln.intro.bullet2"),
            t("mobileCocktailbarKoln.intro.bullet3"),
          ]}
          description={t("mobileCocktailbarKoln.intro.description")}
          image={imageProvider.cocktails.aperolSpritz}
          imagePosition="right"
          link={translatePath("/anfrage/")}
          theme="grey"
          title={t("mobileCocktailbarKoln.intro.title")}
        />
        <TextBlock
          badge={t("mobileCocktailbarKoln.whyKoln.badge")}
          content={`<p>${t("mobileCocktailbarKoln.whyKoln.description")}</p>`}
          theme="light"
          title={t("mobileCocktailbarKoln.whyKoln.title")}
        />
        <ItemList
          badge={t("mobileCocktailbarKoln.locations.badge")}
          columns={2}
          description=""
          items={locationItems}
          title={t("mobileCocktailbarKoln.locations.title")}
          theme="grey"
        />
        <ItemList
          badge={t("mobileCocktailbarKoln.occasions.badge")}
          columns={3}
          description=""
          items={occasionItems}
          title={t("mobileCocktailbarKoln.occasions.title")}
          theme="light"
        />
        <section class="bg-slate-100">
          <div class="mx-auto max-w-7xl px-6 py-12 md:px-12 md:py-20 lg:px-16 lg:py-24 min-[1920px]:max-w-8xl">
            <div class="fade-in-section mb-6 max-w-4xl md:mb-8">
              <div class="mb-4 inline-block rounded-tl-xl rounded-br-xl bg-gradient-to-r from-primary to-primary-light px-3 py-1 md:mb-6">
                <h3 class="font-outfit text-sm uppercase tracking-wider text-white leading-[1.3] md:text-base">
                  {t("mobileCocktailbarKoln.gallery.badge")}
                </h3>
              </div>
              <h2 class="mb-1 font-anton text-3xl leading-tight text-dark md:text-4xl lg:text-5xl">
                {t("mobileCocktailbarKoln.gallery.title")}
              </h2>
              <p class="text-base font-light leading-relaxed text-dark/70 md:text-lg">
                {t("mobileCocktailbarKoln.gallery.description")}
              </p>
            </div>
            <div class="masonry-gallery fade-in-section delay-200">
              {galleryImages.map((item, i) => {
                const aspectClasses = ["aspect-square", "aspect-video", "aspect-[3/4]", "aspect-[4/3]"];
                const aspectClass = aspectClasses[i % aspectClasses.length];
                return (
                  <article class="group masonry-card flex flex-col overflow-hidden rounded-br-4xl bg-white p-0 transition-shadow duration-300 hover:shadow-lg">
                    <div class={`overflow-hidden rounded-br-4xl ${aspectClass}`}>
                      <img
                        src={item.url}
                        alt={item.alt}
                        width={600}
                        height={600}
                        loading="lazy"
                        class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
                        fetchpriority={i < 2 ? "high" : "auto"}
                      />
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        </section>
        <TextBlock
          badge={t("mobileCocktailbarKoln.process.badge")}
          content={t("mobileCocktailbarKoln.process.content")}
          theme="light"
          title={t("mobileCocktailbarKoln.process.title")}
        />
        <FAQ
          badge={t("mobileCocktailbarKoln.faq.badge")}
          description={t("mobileCocktailbarKoln.faq.description")}
          items={faqItems}
          theme="grey"
          title={t("mobileCocktailbarKoln.faq.title")}
        />
        <CallToAction
          badge={t("mobileCocktailbarKoln.cta.badge")}
          buttonText={t("hero.cta")}
          href={translatePath("/anfrage/")}
          theme="light"
          title={t("mobileCocktailbarKoln.cta.ctaTitle")}
        />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style>
  .masonry-gallery {
    column-count: 1;
    column-gap: 1.5rem;
  }
  .masonry-card {
    break-inside: avoid;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .masonry-gallery {
      column-count: 2;
    }
  }
</style>
