---
import { getCollection } from "astro:content";
import BlogIndexLayout from "../../../layouts/BlogIndexLayout.astro";
import { imageProvider } from "../../../provider/imageProvider";

export async function getStaticPaths() {
  const postsPerPage = 6;
  const allPosts = await getCollection("blogDe");
  const totalPages = Math.max(1, Math.ceil(allPosts.length / postsPerPage));
  return Array.from({ length: totalPages - 1 }, (_, pageIndex) => ({
    params: { page: String(pageIndex + 2) },
  }));
}

const POSTS_PER_PAGE = 6;

const { page } = Astro.params;
const pageNum = parseInt(page ?? "2", 10);

const allPosts = (await getCollection("blogDe")).sort(
  (postA, postB) => postB.data.pubDate.valueOf() - postA.data.pubDate.valueOf(),
);
const totalPages = Math.max(1, Math.ceil(allPosts.length / POSTS_PER_PAGE));
const currentPage = Math.min(Math.max(1, pageNum), totalPages);
const start = (currentPage - 1) * POSTS_PER_PAGE;
const posts = allPosts.slice(start, start + POSTS_PER_PAGE).map((blogPost) => ({
  description: blogPost.data.description,
  heroImage: blogPost.data.heroImageKey
    ? imageProvider.blog[blogPost.data.heroImageKey]
    : undefined,
  id: blogPost.id,
  pubDate: blogPost.data.pubDate,
  slug: blogPost.id.replace(/^de\//, ""),
  title: blogPost.data.title,
}));
---

<BlogIndexLayout
  currentPage={currentPage}
  posts={posts}
  totalPages={totalPages}
/>
