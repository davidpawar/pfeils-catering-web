---
import BaseHead from "../components/base/BaseHead.astro";
import Footer from "../components/base/Footer.astro";
import Navigation from "../components/base/Navigation.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={t("datenschutz.meta.title")} description={t("datenschutz.meta.description")} lang={lang} />
  </head>
  <body>
    <div class="relative">
      <Navigation />
      <main class="mx-auto max-w-7xl px-6 py-16 md:px-12 lg:px-16 min-[1920px]:max-w-8xl">
        <h1 class="font-anton text-4xl text-dark">Datenschutz</h1>
        <p class="mt-4 text-dark/70">Inhalt folgt.</p>
      </main>
      <Footer />
    </div>
  </body>
</html>
