---
/**
 * Reusable primary CTA button with gradient styling.
 * Matches the Hero button design.
 */
interface Props {
  /**
   * Optional additional CSS classes (e.g. for margin).
   */
  class?: string;
  /**
   * Target URL for the link.
   */
  href: string;
  /**
   * Button size: sm (compact for nav), md (default), lg (hero).
   */
  size?: "sm" | "md" | "lg";
}

const { href, class: className = "", size = "md" } = Astro.props;

const sizeClasses: Record<NonNullable<Props["size"]>, string> = {
  sm: "rounded-full px-4 py-2 font-outfit text-sm font-medium",
  md: "min-h-12 rounded-full px-6 py-3 font-outfit text-base font-medium md:min-h-14 md:px-8 md:py-4 md:text-lg",
  lg: "min-h-14 rounded-full px-8 py-4 font-outfit text-lg font-medium md:min-h-16 md:px-10 md:py-5 md:text-xl",
};
---

<a
  href={href}
  class:list={[
    "inline-flex w-fit items-center justify-center bg-gradient-to-r from-primary to-primary-light text-white transition-all duration-300 hover:brightness-110 hover:shadow-xl hover:-translate-y-0.5",
    sizeClasses[size],
    className,
  ]}
>
  <slot />
</a>
