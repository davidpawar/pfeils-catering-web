---
import { Mail, MapPin, Phone } from "@lucide/astro";
import { Image } from "astro:assets";
import { getImageAlt } from "../../provider/imageProvider";
import { imageProvider } from "../../provider/imageProvider";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: t("nav.firmenfeier"), href: translatePath("/firmenfeier/") },
  { label: t("nav.hochzeitsfeier"), href: translatePath("/hochzeitsfeier/") },
  { label: t("nav.messeCatering"), href: translatePath("/messe-catering/") },
  {
    label: t("nav.mobileCocktailbar"),
    href: translatePath("/mobile-cocktailbar/"),
  },
  { label: t("nav.anfrage"), href: translatePath("/anfrage/") },
];
---

<footer class="bg-dark-bg text-white">
  <div
    class="mx-auto max-w-7xl px-6 py-12 md:px-12 md:py-16 lg:px-16 lg:py-20 min-[1920px]:max-w-8xl"
  >
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3 md:gap-12 lg:gap-16">
      <!-- Column 1: Company Info -->
      <div class="space-y-4 md:space-y-6">
        <a
          href={translatePath("/")}
          class="flex items-center gap-3 transition-opacity duration-300 hover:opacity-90"
          aria-label={`Pfeil's Catering – ${t("nav.home")}`}
        >
          <Image
            src={imageProvider.logo.altWeiss
              .src as import("astro").ImageMetadata}
            alt={getImageAlt(imageProvider.logo.altWeiss, lang)}
            class="h-12 w-auto md:h-14"
            width={180}
            height={56}
          />
        </a>
        <p class="text-base leading-relaxed text-white/70 md:text-lg">
          {t("footer.tagline")}
        </p>
        <div class="flex gap-4">
          <a
            href="https://www.facebook.com/p/Pfeils-Catering-100039718967749/"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center transition-all duration-300 hover:bg-primary"
            aria-label="Facebook"
          >
            <svg
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <title>Facebook</title>
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/pfeilscatering"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center transition-all duration-300 hover:bg-primary"
            aria-label="Instagram"
          >
            <svg
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <title>Instagram</title>
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="mb-4 font-anton text-lg md:mb-6 md:text-xl">
          {t("footer.quickLinks")}
        </h3>
        <nav class="space-y-3 md:space-y-4">
          {
            quickLinks.map((link) => (
              <a
                href={link.href}
                class="block text-base text-white/70 transition-colors duration-300 hover:text-primary md:text-lg"
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Column 3: Contact Info -->
      <div>
        <h3 class="mb-4 font-anton text-lg md:mb-6 md:text-xl">
          {t("footer.contact")}
        </h3>
        <div class="space-y-4 md:space-y-5">
          <a
            href="tel:01784988521"
            class="flex items-center gap-4 text-white/70 transition-colors duration-300 hover:text-primary group"
          >
            <div
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center transition-all duration-300 group-hover:bg-primary"
            >
              <Phone size={20} stroke-width="1.5" aria-hidden="true" />
            </div>
            <span class="text-base md:text-lg">0178 498 85 21</span>
          </a>
          <a
            href="mailto:info@pfeils-catering.de"
            class="flex items-center gap-4 text-white/70 transition-colors duration-300 hover:text-primary group"
          >
            <div
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center transition-all duration-300 group-hover:bg-primary"
            >
              <Mail size={20} stroke-width="1.5" aria-hidden="true" />
            </div>
            <span class="text-base md:text-lg">info@pfeils-catering.de</span>
          </a>
          <div class="flex items-start gap-4 text-white/70">
            <div
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0"
            >
              <MapPin size={20} stroke-width="1.5" aria-hidden="true" />
            </div>
            <span class="text-base md:text-lg">
              Oberbergischer Kreis
              <br />
              Nordrhein-Westfalen
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div
      class="mx-auto max-w-7xl px-6 py-6 md:px-12 lg:px-16 min-[1920px]:max-w-8xl"
    >
      <div
        class="flex flex-col items-center justify-between gap-4 text-center text-sm text-white/50 md:flex-row md:text-left"
      >
        <p>
          © {currentYear} Pfeil's Cocktail Catering. {t("footer.copyright")}
        </p>
        <div class="flex gap-6">
          <a
            href={translatePath("/impressum/")}
            class="transition-colors hover:text-primary"
          >
            {t("nav.impressum")}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
